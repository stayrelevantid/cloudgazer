# ----------------------------------------------------------------------
# Root Workspace Gitignore
# ----------------------------------------------------------------------
# OS / Editor
.DS_Store
.idea/
.vscode/

# ----------------------------------------------------------------------
# Backend (Go)
# ----------------------------------------------------------------------
/backend/.env
/backend/.env.*
!/backend/.env.example
/backend/tmp/
/backend/bin/
/backend/build/
/backend/costgazer-api # or whatever compiled binary name if you build it

# ----------------------------------------------------------------------
# Frontend (Next.js)
# ----------------------------------------------------------------------
# dependencies
/frontend/node_modules/
/frontend/.pnp
/frontend/.pnp.js

# testing
/frontend/coverage/

# next.js
/frontend/.next/
/frontend/out/

# production
/frontend/build/

# misc
/frontend/.DS_Store
/frontend/*.pem

# debug
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*

# local env files
/frontend/.env
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local
!/frontend/.env.local.example
